#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"

while read -r local_ref _remote_sha remote_ref _local_sha; do
  case "$remote_ref" in
    refs/heads/main)
      cat >&2 <<EOF
Direct pushes to protected branches (${remote_ref#refs/heads/}) are blocked.
Push a feature branch and merge by PR instead.
EOF
      exit 1
      ;;
  esac
done
