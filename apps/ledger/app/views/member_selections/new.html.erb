<% page_title t("member_selections.title") %>

<section class="login-screen">
  <div class="login-panel">
    <div class="login-brand">
      <%= image_tag "/icon.png", alt: "Katorin2", class: "login-brand__mark" %>
      <p class="login-brand__name">Katorin2</p>
    </div>

    <h1 class="member-selection-title"><%= t("member_selections.title") %></h1>
    <p class="login-copy"><%= t("member_selections.lede") %></p>

    <%= form_with url: member_selection_path, class: "login-form", data: { controller: "member-selection" } do |form| %>
      <div class="login-form__row">
        <%= label_tag :organizer_member_id, t("member_selections.member_label"), class: "login-form__label" %>
        <select name="organizer_member_id" class="login-form__input" data-member-selection-target="select" data-action="change->member-selection#toggle">
          <option value=""><%= t("member_selections.select_prompt") %></option>
          <% @members.each do |m| %>
            <option value="<%= m.id %>" <% if m.owner? || m.admin? %>data-privileged="true"<% end %>>
              <%= m.display_name %>（<%= translated_enum("enums.organizer_member.role", m.role) %>）
            </option>
          <% end %>
        </select>
      </div>

      <div class="login-form__row" data-member-selection-target="passwordField" hidden>
        <%= label_tag :admin_password, t("member_selections.admin_password"), class: "login-form__label" %>
        <%= password_field_tag :admin_password, nil, placeholder: t("member_selections.admin_password_placeholder"), autocomplete: "current-password", class: "login-form__input" %>
      </div>

      <div class="login-form__actions">
        <%= form.submit t("member_selections.submit"), class: "button button--auth", disabled: true, data: { member_selection_target: "submit" } %>
      </div>
    <% end %>
  </div>
</section>
