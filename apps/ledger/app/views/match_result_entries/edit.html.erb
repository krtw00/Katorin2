<% page_title t("matches.result_entry.title") %>
<% content_for :content_class, "content--wide" %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@match.league.name, league_path(id: @match.league)),
  breadcrumb_item(@match.phase.name, league_phase_path(league_id: @match.league, id: @match.phase)),
  breadcrumb_item(match_parent_label(@match), match_parent_path(@match)),
  breadcrumb_item(match_title_text(@match), match_path(id: @match)),
  breadcrumb_item(t("matches.result_entry.title"))
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("matches.eyebrow") %></p>
    <h1><%= t("matches.result_entry.title") %></h1>
    <p class="muted"><%= match_title_text(@match) %></p>
  </div>
  <div class="page-actions">
    <% if @match.home_team.present? %>
      <%= link_to t("matches.result_entry.manage_team", team: @match.home_team.display_name), league_team_path(league_id: @match.league, id: @match.home_team, return_to: edit_match_result_entry_path(match_id: @match)), class: "button" %>
    <% end %>
    <% if @match.away_team.present? %>
      <%= link_to t("matches.result_entry.manage_team", team: @match.away_team.display_name), league_team_path(league_id: @match.league, id: @match.away_team, return_to: edit_match_result_entry_path(match_id: @match)), class: "button" %>
    <% end %>
    <%= link_to t("actions.back"), match_path(id: @match), class: "button" %>
    <%= link_to t("actions.edit"), edit_match_path(id: @match), class: "button" %>
  </div>
</section>

<% if @participants_missing_member_ids.present? %>
  <div class="flash flash--warning" role="alert">
    <strong><%= t("matches.result_entry.md_id_warning.heading") %></strong>
    <p class="muted"><%= t("matches.result_entry.md_id_warning.body", players: @participants_missing_member_ids.map(&:display_name).join(" / ")) %></p>
  </div>
<% end %>

<section class="panel">
  <% if @match_result.present? %>
    <div class="kv-list">
      <div><span><%= t("matches.round_wins") %></span><strong><%= @match_result.home_round_wins %> - <%= @match_result.away_round_wins %></strong></div>
      <div><span><%= t("labels.status") %></span><strong><%= translated_enum("enums.match_result.result_status", @match_result.result_status) %></strong></div>
      <div><span><%= t("labels.winner") %></span><strong><%= @match_result.winner_team&.display_name || t("labels.none") %></strong></div>
    </div>
  <% else %>
    <p class="empty-copy"><%= t("matches.result_entry.empty") %></p>
  <% end %>
</section>

<section class="panel result-entry-form-panel">
  <%= form_with url: match_result_entry_path(match_id: @match), method: :patch, scope: :result_entry, class: "stack result-entry-form" do |form| %>
    <% withdrawn_team_labels = [@match.home_team, @match.away_team].compact.select { |team| team.status == "withdrawn" }.map { |team| t("matches.result_entry.withdrawn_team_label", team: team.display_name) } %>
    <% if withdrawn_team_labels.any? %>
      <p class="muted"><%= t("matches.result_entry.withdrawn_note", teams: withdrawn_team_labels.join(" / ")) %></p>
    <% end %>

    <%# KAT-31: 楽観ロック用 hidden field と最終更新者表示 %>
    <%= hidden_field_tag "result_entry[lock_version]", @match_result&.lock_version || 0 %>
    <% if @match_result&.updated_at %>
      <p class="muted">
        <%= t("matches.result_entry.last_saved",
              judge: @match.judge_name.presence || t("labels.none"),
              at: l(@match_result.updated_at.in_time_zone("Asia/Tokyo"), format: :short)) %>
      </p>
    <% end %>

    <% if @stale_conflict %>
      <div class="flash flash--warning" role="alert">
        <strong><%= t("matches.result_entry.stale_conflict_banner") %></strong>
      </div>
    <% end %>

    <div class="field">
      <label for="result_entry_decision_type"><%= t("matches.result_entry.decision_type_label") %></label>
      <%= select_tag "result_entry[decision_type]",
            options_for_select(
              (MatchResult.decision_types.keys - %w[bye]).map { |key| [translated_enum("enums.match_result.decision_type", key), key] },
              @match_result&.decision_type || "normal"
            ),
            include_blank: false,
            id: "result_entry_decision_type",
            data: { result_entry_target: "decisionType" } %>
      <p class="muted"><%= t("matches.result_entry.decision_type_hint") %></p>
    </div>

    <div class="field" data-result-entry-target="penaltySideField" style="<%= (@match_result && MatchResult::PENALTY_REQUIRED_DECISIONS.include?(@match_result.decision_type)) ? "" : "display: none" %>">
      <label for="result_entry_penalty_side"><%= t("matches.result_entry.penalty_side_label") %></label>
      <%= select_tag "result_entry[penalty_side]",
            options_for_select(
              [
                [t("matches.result_entry.penalty_side_home", team: match_side_name(@match, "home")), "home"],
                [t("matches.result_entry.penalty_side_away", team: match_side_name(@match, "away")), "away"],
              ],
              @match_result&.penalty_side
            ),
            include_blank: t("matches.form.select_prompt"),
            id: "result_entry_penalty_side" %>
      <p class="muted"><%= t("matches.result_entry.penalty_side_hint") %></p>
    </div>

    <div data-result-entry-target="roundsContainer" style="<%= (@match_result && MatchResult::PENALTY_REQUIRED_DECISIONS.include?(@match_result.decision_type)) ? "display: none" : "" %>">
    <% @round_entries.each do |entry| %>
      <% round = entry[:round] %>
      <% unconfirmed = round.result_status != "confirmed" %>
      <article class="panel panel--nested<%= " is-unconfirmed" if unconfirmed %>" data-round-article="<%= round.number %>">
        <div class="panel-header">
          <div>
            <h2><%= t("matches.result_entry.round_title", number: round.number) %></h2>
            <p class="muted"><%= translated_enum("enums.match_result.result_status", round.result_status || "partial") %></p>
          </div>
          <div class="panel-header__actions">
            <button type="button"
                    class="button button--ghost"
                    data-clear-round="<%= round.number %>"
                    data-confirm-message="<%= t("matches.result_entry.clear_round_confirm", number: round.number) %>">
              <%= t("matches.result_entry.clear_round") %>
            </button>
            <button type="button"
                    class="button button--ghost"
                    data-undo-clear-round="<%= round.number %>"
                    hidden>
              <%= t("matches.result_entry.undo_clear_round") %>
            </button>
            <span class="muted result-entry-cleared-note" data-cleared-note="<%= round.number %>" hidden><%= t("matches.result_entry.cleared_note") %></span>
          </div>
        </div>

        <div class="result-entry-table">
          <div class="result-entry-table__header">
            <span><%= t("labels.board") %></span>
            <span><%= t("matches.result_entry.member_short", team: match_side_name(@match, "home")) %></span>
            <span><%= t("matches.result_entry.deck_short", team: match_side_name(@match, "home")) %></span>
            <span><%= t("labels.score") %></span>
            <span><%= t("matches.result_entry.deck_short", team: match_side_name(@match, "away")) %></span>
            <span><%= t("matches.result_entry.member_short", team: match_side_name(@match, "away")) %></span>
          </div>

          <% entry[:boards].each do |board| %>
            <div class="result-entry-row">
              <div class="result-entry-cell result-entry-cell--board" data-label="<%= t("labels.board") %>">
                <div class="result-entry-row__board">#<%= board.board_number %></div>
              </div>

              <div class="result-entry-cell" data-label="<%= t("matches.result_entry.member_short", team: match_side_name(@match, "home")) %>">
                <div class="field field--compact">
                  <label class="sr-only"><%= t("matches.result_entry.board_member", number: board.board_number, team: match_side_name(@match, "home")) %></label>
                  <%= select_tag "result_entry[rounds][#{round.number}][boards][#{board.board_number}][home_participant_id]", options_from_collection_for_select(@home_participant_options, :id, :display_name, board.home_participant_id), include_blank: t("matches.form.select_prompt"), aria: { label: t("matches.result_entry.board_member", number: board.board_number, team: match_side_name(@match, "home")) } %>
                </div>
              </div>

              <div class="result-entry-cell" data-label="<%= t("matches.result_entry.deck_short", team: match_side_name(@match, "home")) %>">
                <div class="field field--compact">
                  <label class="sr-only"><%= t("matches.result_entry.deck_name", team: match_side_name(@match, "home")) %></label>
                  <%= text_field_tag "result_entry[rounds][#{round.number}][boards][#{board.board_number}][home_deck_name]", board.home_deck_name, placeholder: t("matches.result_entry.deck_placeholder"), aria: { label: t("matches.result_entry.deck_name", team: match_side_name(@match, "home")) } %>
                </div>
              </div>

              <div class="result-entry-cell" data-label="<%= t("labels.score") %>">
                <div class="result-entry-score">
                  <div class="field field--compact">
                    <label class="sr-only"><%= t("matches.result_entry.game_wins", team: match_side_name(@match, "home")) %></label>
                    <%= select_tag "result_entry[rounds][#{round.number}][boards][#{board.board_number}][home_game_wins]", options_for_select(game_win_options, board.home_game_wins), include_blank: false, class: "result-entry-score__select", aria: { label: t("matches.result_entry.game_wins", team: match_side_name(@match, "home")) } %>
                  </div>
                  <span class="result-entry-score__sep">-</span>
                  <div class="field field--compact">
                    <label class="sr-only"><%= t("matches.result_entry.game_wins", team: match_side_name(@match, "away")) %></label>
                    <%= select_tag "result_entry[rounds][#{round.number}][boards][#{board.board_number}][away_game_wins]", options_for_select(game_win_options, board.away_game_wins), include_blank: false, class: "result-entry-score__select", aria: { label: t("matches.result_entry.game_wins", team: match_side_name(@match, "away")) } %>
                  </div>
                </div>
              </div>

              <div class="result-entry-cell" data-label="<%= t("matches.result_entry.deck_short", team: match_side_name(@match, "away")) %>">
                <div class="field field--compact">
                  <label class="sr-only"><%= t("matches.result_entry.deck_name", team: match_side_name(@match, "away")) %></label>
                  <%= text_field_tag "result_entry[rounds][#{round.number}][boards][#{board.board_number}][away_deck_name]", board.away_deck_name, placeholder: t("matches.result_entry.deck_placeholder"), aria: { label: t("matches.result_entry.deck_name", team: match_side_name(@match, "away")) } %>
                </div>
              </div>

              <div class="result-entry-cell" data-label="<%= t("matches.result_entry.member_short", team: match_side_name(@match, "away")) %>">
                <div class="field field--compact">
                  <label class="sr-only"><%= t("matches.result_entry.board_member", number: board.board_number, team: match_side_name(@match, "away")) %></label>
                  <%= select_tag "result_entry[rounds][#{round.number}][boards][#{board.board_number}][away_participant_id]", options_from_collection_for_select(@away_participant_options, :id, :display_name, board.away_participant_id), include_blank: t("matches.form.select_prompt"), aria: { label: t("matches.result_entry.board_member", number: board.board_number, team: match_side_name(@match, "away")) } %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </article>
    <% end %>
    </div>

    <div class="page-actions">
      <%= link_to t("actions.back"), match_path(id: @match), class: "button" %>
      <%= form.submit t("matches.result_entry.submit"), class: "button button--primary" %>
      <% if @stale_conflict %>
        <button type="submit"
                name="result_entry[force_overwrite]"
                value="1"
                class="button button--danger"
                data-confirm-message="<%= t("matches.result_entry.force_overwrite_confirm") %>"
                onclick="return confirm(this.dataset.confirmMessage);">
          <%= t("matches.result_entry.force_overwrite") %>
        </button>
      <% end %>
    </div>
  <% end %>
</section>

<script>
  (function () {
    var FORFEIT_DECISIONS = <%= MatchResult::PENALTY_REQUIRED_DECISIONS.to_json.html_safe %>;
    var decisionSelect = document.getElementById("result_entry_decision_type");
    var penaltyField = document.querySelector('[data-result-entry-target="penaltySideField"]');
    var roundsContainer = document.querySelector('[data-result-entry-target="roundsContainer"]');
    if (!decisionSelect || !penaltyField || !roundsContainer) return;

    function refresh() {
      var forfeit = FORFEIT_DECISIONS.indexOf(decisionSelect.value) !== -1;
      penaltyField.style.display = forfeit ? "" : "none";
      roundsContainer.style.display = forfeit ? "none" : "";
    }
    decisionSelect.addEventListener("change", refresh);
    refresh();
  })();

  // KAT-30: ラウンド単位のクリア (= disabled 化で submit 時に round payload を空にし、 recorder の board 全 blank → destroy ロジックに乗せる)
  (function () {
    function inputsIn(article) {
      return article.querySelectorAll('select, input[type="text"]');
    }
    document.querySelectorAll('[data-clear-round]').forEach(function (button) {
      button.addEventListener('click', function () {
        var number = button.getAttribute('data-clear-round');
        var msg = button.getAttribute('data-confirm-message');
        if (msg && !confirm(msg)) return;
        var article = document.querySelector('[data-round-article="' + number + '"]');
        if (!article) return;
        inputsIn(article).forEach(function (el) {
          el.disabled = true;
          if (el.tagName === 'SELECT') {
            el.selectedIndex = 0;
          } else {
            el.value = '';
          }
        });
        article.classList.add('is-cleared');
        button.hidden = true;
        var undo = article.querySelector('[data-undo-clear-round="' + number + '"]');
        var note = article.querySelector('[data-cleared-note="' + number + '"]');
        if (undo) undo.hidden = false;
        if (note) note.hidden = false;
      });
    });

    document.querySelectorAll('[data-undo-clear-round]').forEach(function (button) {
      button.addEventListener('click', function () {
        var number = button.getAttribute('data-undo-clear-round');
        var article = document.querySelector('[data-round-article="' + number + '"]');
        if (!article) return;
        inputsIn(article).forEach(function (el) { el.disabled = false; });
        article.classList.remove('is-cleared');
        button.hidden = true;
        var clearBtn = article.querySelector('[data-clear-round="' + number + '"]');
        var note = article.querySelector('[data-cleared-note="' + number + '"]');
        if (clearBtn) clearBtn.hidden = false;
        if (note) note.hidden = true;
      });
    });
  })();
</script>
