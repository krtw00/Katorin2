<% page_title t("home.title") %>

<section class="hero hero--landing">
  <div class="hero-card hero-card--stone">
    <p class="eyebrow"><%= ::RuleModules::Registry.default.display_name %></p>
    <h1><%= t("home.title") %></h1>
    <p class="lede">
      <%= t("home.lede") %>
    </p>

    <div class="hero-actions">
      <%= link_to t("home.login"), new_session_path, class: "button button--primary" %>
    </div>
  </div>

  <div class="hero-card hero-card--gem">
    <h2><%= t("home.features_title") %></h2>
    <ul class="feature-list">
      <li><%= t("home.features.leagues") %></li>
      <li><%= t("home.features.results") %></li>
      <li><%= t("home.features.exports") %></li>
    </ul>
  </div>
</section>
