<% page_title @week.display_name %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@phase.league.name, league_path(id: @phase.league)),
  breadcrumb_item(@phase.name, league_phase_path(league_id: @phase.league, id: @phase)),
  breadcrumb_item(@week.display_name)
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("weeks.eyebrow") %></p>
    <h1><%= @week.display_name %></h1>
    <p class="muted"><%= t("weeks.meta", number: @week.number, phase: @phase.name) %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_phase_path(league_id: @phase.league, id: @phase), class: "button" %>
    <% if can_manage? %>
      <%= link_to t("actions.edit"), edit_phase_week_path(phase_id: @phase, id: @week), class: "button" %>
    <% end %>
  </div>
</section>

<section class="stack">
  <article class="panel">
    <div class="panel-header">
      <div>
        <h2><%= t("decks.usage.title") %></h2>
        <p class="muted"><%= t("decks.usage.scope_note") %></p>
      </div>
      <% if @deck_usage_summary.entries.any? %>
        <div class="page-actions">
          <%= link_to t("decks.usage.download_csv"), deck_usage_csv_phase_week_path(phase_id: @phase, id: @week, format: :csv), class: "button" %>
        </div>
      <% end %>
    </div>

    <% if @deck_usage_summary.entries.any? %>
      <div class="table-scroll">
        <table class="standings-table">
          <thead>
            <tr>
              <th><%= t("decks.usage.columns.deck_name") %></th>
              <th><%= t("decks.usage.columns.user_count") %></th>
              <th><%= t("decks.usage.columns.wins") %></th>
              <th><%= t("decks.usage.columns.losses") %></th>
              <th><%= t("decks.usage.columns.win_rate") %></th>
            </tr>
          </thead>
          <tbody>
            <% @deck_usage_summary.entries.each do |entry| %>
              <tr>
                <td><%= entry.deck_name %></td>
                <td><%= entry.user_count %></td>
                <td><%= entry.wins %></td>
                <td><%= entry.losses %></td>
                <td><%= entry.win_rate.nil? ? t("decks.usage.win_rate_unavailable") : number_to_percentage(entry.win_rate * 100, precision: 1) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("decks.usage.empty") %></p>
    <% end %>
  </article>

  <% if @matches.any? %>
    <% @block_sections.each do |block, matches| %>
      <article class="panel">
        <div class="panel-header">
          <div>
            <h2><%= block&.name || t("weeks.unassigned_block") %></h2>
          </div>
          <div class="page-actions">
            <% if can_manage? %>
              <%= link_to t("actions.create_match"), new_week_match_path(week_id: @week, block_id: block&.id), class: "button" %>
            <% end %>
          </div>
        </div>
        <% if matches.any? %>
          <ul class="record-list">
            <% matches.each do |match| %>
              <li><%= render "matches/row", match: match %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-copy"><%= t("weeks.empty_matches") %></p>
        <% end %>
      </article>
    <% end %>
  <% else %>
    <article class="panel">
      <% if @phase.blocks.any? %>
        <% @phase.blocks.order(:position).each do |block| %>
          <div class="panel-header">
            <div>
              <h2><%= block.name %></h2>
            </div>
            <div class="page-actions">
              <% if can_manage? %>
                <%= link_to t("actions.create_match"), new_week_match_path(week_id: @week, block_id: block.id), class: "button" %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <h2><%= t("weeks.matches") %></h2>
        <% if can_manage? %>
          <div class="page-actions">
            <%= link_to t("actions.create_match"), new_week_match_path(week_id: @week), class: "button" %>
          </div>
        <% end %>
      <% end %>
    </article>
  <% end %>
</section>
