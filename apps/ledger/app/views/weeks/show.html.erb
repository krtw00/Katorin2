<% page_title @week.display_name %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@phase.league.name, league_path(id: @phase.league)),
  breadcrumb_item(@phase.name, league_phase_path(league_id: @phase.league, id: @phase)),
  breadcrumb_item(@week.display_name)
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("weeks.eyebrow") %></p>
    <h1><%= @week.display_name %></h1>
    <p class="muted"><%= t("weeks.meta", number: @week.number, kind: translated_enum("enums.week.kind", @week.kind)) %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_phase_path(league_id: @phase.league, id: @phase), class: "button" %>
    <%= link_to t("actions.edit"), edit_phase_week_path(phase_id: @phase, id: @week), class: "button" %>
  </div>
</section>

<section class="stack">
  <% if @matches.any? %>
    <% @block_sections.each do |block, matches| %>
      <article class="panel">
        <div class="panel-header">
          <div>
            <h2><%= block&.name || t("weeks.unassigned_block") %></h2>
          </div>
          <div class="page-actions">
            <%= link_to t("actions.create_match"), new_week_match_path(week_id: @week, block_id: block&.id), class: "button" %>
          </div>
        </div>
        <% if matches.any? %>
          <ul class="record-list">
            <% matches.each do |match| %>
              <li><%= render "matches/row", match: match %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-copy"><%= t("weeks.empty_matches") %></p>
        <% end %>
      </article>
    <% end %>
  <% else %>
    <article class="panel">
      <% if @phase.blocks.any? %>
        <% @phase.blocks.order(:position).each do |block| %>
          <div class="panel-header">
            <div>
              <h2><%= block.name %></h2>
            </div>
            <div class="page-actions">
              <%= link_to t("actions.create_match"), new_week_match_path(week_id: @week, block_id: block.id), class: "button" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <h2><%= t("weeks.matches") %></h2>
        <div class="page-actions">
          <%= link_to t("actions.create_match"), new_week_match_path(week_id: @week), class: "button" %>
        </div>
      <% end %>
    </article>
  <% end %>
</section>
