<% page_title t("stage_assets.title_index") %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("stage_assets.eyebrow") %></p>
    <h1><%= t("stage_assets.title_index") %></h1>
    <p class="muted"><%= t("stage_assets.lede") %></p>
  </div>
  <% if can_manage? %>
    <div class="page-actions">
      <%= link_to t("actions.create_stage_asset"), new_stage_asset_path, class: "button button--primary" %>
    </div>
  <% end %>
</section>

<section class="stack">
  <% @stage_assets.each do |stage_asset| %>
    <article class="panel">
      <div class="panel-header">
        <div>
          <h2><%= stage_asset.name_ja %> <span class="muted">/ <%= stage_asset.display_name_en %></span></h2>
          <p class="muted"><code><%= stage_asset.key %></code></p>
        </div>
        <div class="page-actions">
          <%= status_badge translated_enum("rulesets.formats", stage_asset.format), "neutral" %>
          <%= status_badge stage_asset.active? ? t("labels.on") : t("labels.off"), stage_asset.active? ? "success" : "neutral" %>
          <% if can_manage? %>
            <%= link_to t("actions.edit"), edit_stage_asset_path(id: stage_asset), class: "button" %>
            <%= button_to t("actions.delete"), stage_asset_path(id: stage_asset), method: :delete, class: "button button--danger", form: { data: { turbo_confirm: t("stage_assets.delete_confirm") } } %>
          <% end %>
        </div>
      </div>

      <% if stage_asset.description_ja.present? %>
        <p class="muted"><%= stage_asset.description_ja %></p>
      <% end %>
      <% if stage_asset.description_en.present? && stage_asset.description_en != stage_asset.description_ja %>
        <p class="muted"><%= stage_asset.description_en %></p>
      <% end %>

      <ul class="compact-list">
        <li><strong><%= t("stage_assets.labels.participant_scope") %>:</strong> <%= translated_enum("rulesets.participant_scopes", stage_asset.participant_scope) %></li>
      </ul>
    </article>
  <% end %>
</section>
