<% page_title t("organizer_members.title_index") %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("organizer_members.eyebrow") %></p>
    <h1><%= t("organizer_members.title_index") %></h1>
    <p class="muted"><%= t("organizer_members.lede") %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.create_organizer_member"), new_organizer_member_path, class: "button button--primary" %>
  </div>
</section>

<section class="stack">
  <% @organizer_members.each do |organizer_member| %>
    <article class="panel">
      <div class="panel-header">
        <div>
          <h2><%= organizer_member.display_name %></h2>
          <p class="muted"><%= translated_enum("enums.organizer_member.role", organizer_member.role) %></p>
        </div>
        <div class="page-actions">
          <%= status_badge organizer_member.active? ? t("labels.on") : t("labels.off"), organizer_member.active? ? "success" : "neutral" %>
          <%= link_to t("actions.edit"), edit_organizer_member_path(organizer_member), class: "button" %>
        </div>
      </div>
      <% if organizer_member.notes.present? %>
        <p class="muted"><%= organizer_member.notes %></p>
      <% end %>
    </article>
  <% end %>
</section>
