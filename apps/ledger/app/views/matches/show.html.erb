<% page_title "#{@match.home_team.display_name} vs #{@match.away_team.display_name}" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Match</p>
    <h1><%= @match.home_team.display_name %> vs <%= @match.away_team.display_name %></h1>
    <p class="muted">
      <%= @match.phase.name %> / <%= @match.week.name %>
      <% if @match.scheduled_on %>
        / <%= @match.scheduled_on %>
      <% end %>
      <% if @match.scheduled_time %>
        <%= @match.scheduled_time.strftime("%H:%M") %>
      <% end %>
    </p>
  </div>
  <div class="page-actions">
    <%= link_to "Weekへ戻る", phase_week_path(@match.phase, @match.week), class: "button" %>
    <%= link_to "編集", edit_match_path(@match), class: "button button--primary" %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2>進行状況</h2>
    <div class="kv-list">
      <div><span>status</span><strong><%= @match.status %></strong></div>
      <div><span>export</span><strong><%= @match.export_status %></strong></div>
      <div><span>Judge</span><strong><%= @match.judge_name.presence || "-" %></strong></div>
      <div><span>Room</span><strong><%= @match.room_id.presence || "-" %></strong></div>
      <div><span>Spectator</span><strong><%= @match.spectator_room_id.presence || "-" %></strong></div>
      <div><span>Block</span><strong><%= @match.block&.name || "-" %></strong></div>
    </div>
  </article>

  <article class="panel">
    <h2>公式結果</h2>
    <% if @match_result %>
      <div class="kv-list">
        <div><span>ラウンド勝数</span><strong><%= @match_result.home_round_wins %> - <%= @match_result.away_round_wins %></strong></div>
        <div><span>winner</span><strong><%= @match_result.winner_team&.display_name || "-" %></strong></div>
        <div><span>status</span><strong><%= @match_result.result_status %></strong></div>
        <div><span>decision</span><strong><%= @match_result.decision_type %></strong></div>
      </div>
    <% else %>
      <p class="empty-copy">公式結果はまだありません。</p>
    <% end %>
  </article>

  <article class="panel">
    <h2>Rounds</h2>
    <% if @rounds.any? %>
      <ul class="compact-list">
        <% @rounds.each do |round| %>
          <li>
            Round <%= round.number %> / <%= round.result_status %> / 卓数 <%= round.board_results.size %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy">Round はまだありません。</p>
    <% end %>
  </article>
</section>
