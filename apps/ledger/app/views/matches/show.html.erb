<% page_title match_title_text(@match) %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@match.league.name, league_path(id: @match.league)),
  breadcrumb_item(@match.phase.name, league_phase_path(league_id: @match.league, id: @match.phase)),
  breadcrumb_item(match_parent_label(@match), match_parent_path(@match)),
  breadcrumb_item(match_title_text(@match))
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("matches.eyebrow") %></p>
    <h1><%= match_title_text(@match) %></h1>
    <p class="muted">
      <%= @match.phase.name %> / <%= match_parent_label(@match) %>
      <% if @match.scheduled_on %>
        / <%= @match.scheduled_on %>
      <% end %>
      <% if @match.scheduled_time %>
        <%= @match.scheduled_time.strftime("%H:%M") %>
      <% end %>
    </p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), match_parent_path(@match), class: "button" %>
    <% if can_manage? %>
      <%= link_to t("actions.edit"), edit_match_path(id: @match), class: "button button--primary" %>
    <% end %>
    <% if @match.ready_for_result_entry? %>
      <%= link_to t("actions.edit_lineup"), edit_match_lineup_path(match_id: @match), class: "button" %>
      <%= link_to t("actions.edit_result"), edit_match_result_entry_path(match_id: @match), class: "button" %>
      <%= link_to t("actions.download_export"), download_match_result_card_export_path(match_id: @match), class: "button" %>
    <% end %>
    <% if can_manage? && @match.destroyable? %>
      <%= button_to t("actions.delete"), match_path(id: @match), method: :delete, class: "button button--danger", form: { data: { turbo_confirm: t("matches.delete_confirm") } } %>
    <% end %>
  </div>
</section>

<% if @match.ready_for_result_entry? %>
  <p class="muted">
    <%= status_badge(result_card_export_status_label(@result_card_export_state), result_card_export_status_tone(@result_card_export_state)) %>
    <%= result_card_export_hint(@result_card_export_state) %>
  </p>
<% end %>

<section class="dashboard-grid">
  <article class="panel">
    <h2><%= t("matches.progress") %></h2>
    <div class="kv-list">
      <div><span><%= t("labels.status") %></span><strong><%= translated_enum("enums.match.status", @match.status) %></strong></div>
      <div><span><%= t("labels.judge") %></span><strong><%= @match.judge_name.presence || t("labels.none") %></strong></div>
      <div><span><%= t("labels.room") %></span><strong><%= @match.room_id.presence || t("labels.none") %></strong></div>
      <div><span><%= t("labels.spectator") %></span><strong><%= @match.spectator_room_id.presence || t("labels.none") %></strong></div>
      <div><span><%= t("labels.block") %></span><strong><%= @match.block&.name || t("labels.none") %></strong></div>
      <% if @match.bracket_match? %>
        <div><span><%= t("phases.bracket") %></span><strong><%= @match.bracket_slot_label %></strong></div>
      <% end %>
    </div>
  </article>

  <% if @match.ready_for_result_entry? %>
    <article class="panel">
    <h2><%= t("matches.lineup.title") %></h2>
    <div class="dashboard-grid">
      <article class="panel panel--nested">
        <h3><%= match_side_name(@match, "home") %></h3>
        <% if @match.lineup_members_for("home").any? %>
          <ul class="compact-list">
            <% @match.lineup_members_for("home").each do |entry| %>
              <li><%= t("matches.lineup.summary", role: translated_enum("enums.match_lineup_member.role", entry.role), number: entry.slot_number, name: entry.participant.display_name) %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-copy"><%= t("matches.lineup.empty") %></p>
        <% end %>
      </article>

      <article class="panel panel--nested">
        <h3><%= match_side_name(@match, "away") %></h3>
        <% if @match.lineup_members_for("away").any? %>
          <ul class="compact-list">
            <% @match.lineup_members_for("away").each do |entry| %>
              <li><%= t("matches.lineup.summary", role: translated_enum("enums.match_lineup_member.role", entry.role), number: entry.slot_number, name: entry.participant.display_name) %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-copy"><%= t("matches.lineup.empty") %></p>
        <% end %>
      </article>
    </div>
    </article>
  <% end %>

  <article class="panel">
    <h2><%= t("matches.official_result") %></h2>
    <% if @match_result %>
      <div class="kv-list">
        <div><span><%= t("matches.round_wins") %></span><strong><%= @match_result.home_round_wins %> - <%= @match_result.away_round_wins %></strong></div>
        <div><span><%= t("labels.winner") %></span><strong><%= @match_result.winner_team&.display_name || t("labels.none") %></strong></div>
        <div><span><%= t("labels.status") %></span><strong><%= translated_enum("enums.match_result.result_status", @match_result.result_status) %></strong></div>
        <div><span><%= t("labels.decision") %></span><strong><%= translated_enum("enums.match_result.decision_type", @match_result.decision_type) %></strong></div>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("matches.empty_result") %></p>
    <% end %>
  </article>

  <article class="panel">
    <h2><%= t("matches.schedule_candidates.title") %></h2>
    <% candidates = @match.schedule_candidates.reject { |c| c.withdrawn? } %>
    <% if @match.accepted_schedule_candidate_id.present? && (accepted = @match.accepted_schedule_candidate) %>
      <p>
        <strong><%= t("matches.schedule_candidates.confirmed_at") %>:</strong>
        <%= display_schedule(accepted.starts_at, accepted.submitter_tz) %>
        <span class="muted">(JST <%= accepted.starts_at.in_time_zone("Asia/Tokyo").strftime("%Y/%m/%d %H:%M") %>)</span>
      </p>
    <% elsif candidates.empty? %>
      <p class="empty-copy"><%= t("matches.schedule_candidates.empty") %></p>
    <% else %>
      <ul class="compact-list">
        <% candidates.each do |candidate| %>
          <li>
            <strong><%= display_schedule(candidate.starts_at, candidate.submitter_tz) %></strong>
            <span class="muted">/ JST <%= candidate.starts_at.in_time_zone("Asia/Tokyo").strftime("%Y/%m/%d %H:%M") %></span>
            <span class="muted">/ <%= t("matches.schedule_candidates.submitted_by", team: candidate.submitter_team.display_name) %></span>
            <% if candidate.notes.present? %>
              <p class="muted"><%= candidate.notes %></p>
            <% end %>
            <% if can_manage? && candidate.proposed? %>
              <%= button_to t("matches.schedule_candidates.accept"),
                accept_match_schedule_candidate_path(match_id: @match, id: candidate),
                method: :post,
                class: "button button--primary button--small",
                form: { data: { turbo_confirm: t("matches.schedule_candidates.accept_confirm") } } %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </article>

  <article class="panel">
    <h2><%= t("matches.rounds") %></h2>
    <% if @rounds.any? %>
      <ul class="compact-list">
        <% @rounds.each do |round| %>
          <li>
            <%= t("matches.rounds_count", number: round.number, status: translated_enum("enums.match_result.result_status", round.result_status), count: round.board_results.size) %>
            <% if round.board_results.any? %>
              <ul class="compact-list compact-list--nested">
                <% round.board_results.each do |board| %>
                  <li>
                    <%= t("matches.result_entry.board_summary_with_score",
                      number: board.board_number,
                      home: board.home_participant&.display_name || t("labels.none"),
                      home_deck: board.home_deck_name.presence || t("labels.none"),
                      home_score: board.home_game_wins.nil? ? t("labels.none") : board.home_game_wins,
                      away_score: board.away_game_wins.nil? ? t("labels.none") : board.away_game_wins,
                      away_deck: board.away_deck_name.presence || t("labels.none"),
                      away: board.away_participant&.display_name || t("labels.none")) %>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("matches.empty_rounds") %></p>
    <% end %>
  </article>
</section>
