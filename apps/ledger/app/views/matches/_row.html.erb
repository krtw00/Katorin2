<div class="record-row">
  <div class="record-row__body">
    <strong class="record-row__title"><%= link_to "#{match.home_team.display_name} #{t("labels.vs")} #{match.away_team.display_name}", edit_match_result_entry_path(match_id: match) %></strong>
    <div class="muted record-row__subtext">
      <%= match.phase.name %> / <%= match.week.display_name %>
      <% if match.scheduled_on %>
        / <%= match.scheduled_on %>
      <% end %>
      <% if match.scheduled_time %>
        <%= match.scheduled_time.strftime("%H:%M") %>
      <% end %>
    </div>
  </div>
  <div class="record-row__meta">
    <%= status_badge translated_enum("enums.match.status", match.status), "neutral" %>
    <%= link_to t("matches.lineup.short"), edit_match_lineup_path(match_id: match), class: "inline-link" %>
    <%= link_to t("matches.result_entry.short"), edit_match_result_entry_path(match_id: match), class: "inline-link" %>
  </div>
</div>
