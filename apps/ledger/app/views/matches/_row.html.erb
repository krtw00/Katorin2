<div class="record-row">
  <div class="record-row__body">
    <strong class="record-row__title"><%= link_to match_title_text(match), match_path(id: match) %></strong>
    <div class="muted record-row__subtext">
      <%= match.phase.name %> / <%= match_parent_label(match) %>
      <% if match.scheduled_on %>
        / <%= match.scheduled_on %>
      <% end %>
      <% if match.scheduled_time %>
        <%= match.scheduled_time.strftime("%H:%M") %>
      <% end %>
    </div>
  </div>
  <div class="record-row__meta">
    <%= status_badge translated_enum("enums.match.status", match.status), "neutral" %>
    <% if match.ready_for_result_entry? %>
      <%= link_to t("matches.lineup.short"), edit_match_lineup_path(match_id: match), class: "inline-link record-row__action-link record-row__action-link--lineup" %>
      <%= link_to t("matches.result_entry.short"), edit_match_result_entry_path(match_id: match), class: "inline-link record-row__action-link record-row__action-link--result" %>
    <% end %>
  </div>
</div>
