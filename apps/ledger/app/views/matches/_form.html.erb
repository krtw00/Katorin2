<%= render "shared/errors", record: match %>

<% form_url = match.persisted? ? match_path(id: match) : week_matches_path(week_id: week) %>
<% form_method = match.persisted? ? :patch : :post %>

<%= form_with model: match, url: form_url, method: form_method, class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :home_team_id, t("matches.form.home_team") %>
      <%= form.collection_select :home_team_id, @team_options, :id, :display_name, prompt: t("matches.form.select_prompt") %>
    </div>

    <div class="field">
      <%= form.label :away_team_id, t("matches.form.away_team") %>
      <%= form.collection_select :away_team_id, @team_options, :id, :display_name, prompt: t("matches.form.select_prompt") %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :block_id, t("matches.form.block") %>
      <%= form.collection_select :block_id, @block_options, :id, :name, include_blank: true %>
    </div>

    <div class="field">
      <%= form.label :stage_key, t("matches.form.stage_key") %>
      <%= form.text_field :stage_key %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :scheduled_on, t("matches.form.scheduled_on") %>
      <%= form.date_field :scheduled_on %>
    </div>

    <div class="field">
      <%= form.label :scheduled_time, t("matches.form.scheduled_time") %>
      <%= form.time_field :scheduled_time %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :status, t("matches.form.status") %>
      <%= form.select :status, enum_options("enums.match.status", Match::STATUSES.values) %>
    </div>

    <div class="field">
      <%= form.label :export_status, t("matches.form.export_status") %>
      <%= form.select :export_status, enum_options("enums.match.export_status", Match::EXPORT_STATUSES.values) %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :judge_name, t("matches.form.judge_name") %>
      <%= form.text_field :judge_name %>
    </div>

    <div class="field">
      <%= form.label :bracket_slot, t("matches.form.bracket_slot") %>
      <%= form.text_field :bracket_slot %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :room_id, t("matches.form.room_id") %>
      <%= form.text_field :room_id %>
    </div>

    <div class="field">
      <%= form.label :spectator_room_id, t("matches.form.spectator_room_id") %>
      <%= form.text_field :spectator_room_id %>
    </div>
  </div>

  <div class="field">
    <%= form.label :notes, t("matches.form.notes") %>
    <%= form.text_area :notes, rows: 4 %>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), match.persisted? ? match_path(id: match) : phase_week_path(phase_id: week.phase, id: week), class: "button" %>
    <%= form.submit class: "button button--primary" %>
  </div>
<% end %>
