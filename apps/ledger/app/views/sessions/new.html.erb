<% page_title t("sessions.title") %>

<section class="login-screen">
  <div class="login-panel">
    <div class="login-brand">
      <%= image_tag "/icon.png", alt: "Katorin2", class: "login-brand__mark" %>
      <p class="login-brand__name">Katorin2</p>
    </div>

    <%= form_with url: session_path, class: "login-form" do |form| %>
      <div class="login-form__row">
        <%= form.label :login_id, t("sessions.login_id"), class: "login-form__label" %>
        <%= form.text_field :login_id, required: true, autofocus: true, autocomplete: "username", class: "login-form__input" %>
      </div>

      <div class="login-form__row">
        <%= form.label :password, t("sessions.password"), class: "login-form__label" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", class: "login-form__input" %>
      </div>

      <div class="login-form__actions">
        <%= form.submit t("sessions.submit"), class: "button button--auth" %>
      </div>
    <% end %>
  </div>
</section>
