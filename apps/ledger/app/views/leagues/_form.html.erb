<%= render "shared/errors", record: league %>

<%= form_with model: league, class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :name, t("leagues.form.name") %>
      <%= form.text_field :name, required: true %>
      <p class="ghost-note"><%= t("leagues.form.identifier_hint") %></p>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :status, t("leagues.form.status") %>
      <%= form.select :status, enum_options("enums.league.status", ["draft", "active", "completed"]) %>
      <p class="ghost-note"><%= t("leagues.form.stage_asset_hint") %></p>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :started_at, t("leagues.form.started_at") %>
      <%= form.date_field :started_at %>
    </div>

    <div class="field">
      <%= form.label :ended_at, t("leagues.form.ended_at") %>
      <%= form.date_field :ended_at %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :header_image, t("leagues.form.header_image") %>
      <%= form.file_field :header_image, accept: "image/png,image/jpeg,image/webp" %>
      <p class="ghost-note"><%= t("leagues.form.header_image_hint") %></p>
      <% if league.header_image.attached? %>
        <div class="image-preview-card">
          <%= image_tag league.header_image, alt: t("leagues.form.header_image"), class: "image-preview-card__image" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), league.persisted? ? league_path(id: league) : leagues_path, class: "button" %>
    <%= form.submit class: "button button--primary" %>
  </div>
<% end %>
