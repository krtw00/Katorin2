<% page_title t("leagues.title_index") %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"))
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("leagues.eyebrow_index") %></p>
    <h1><%= t("leagues.title_index") %></h1>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.create_league"), new_league_path, class: "button button--primary" %>
  </div>
</section>

<section class="stack">
  <% @leagues.each do |league| %>
    <article class="panel">
      <div class="panel-header">
        <div>
          <h2><%= link_to league.name, league_path(id: league) %></h2>
          <p class="muted"><%= league_reference_text(league) %></p>
        </div>
        <%= status_badge translated_enum("enums.league.status", league.status), "neutral" %>
      </div>
    </article>
  <% end %>
</section>
