<% page_title @league.name %>

<section class="page-header">
  <div>
    <p class="eyebrow">League</p>
    <h1><%= @league.name %></h1>
    <p class="muted">ルール: <%= @league.rule_module_key %> / slug: <%= @league.slug %></p>
  </div>
  <div class="page-actions">
    <%= link_to "編集", edit_league_path(@league), class: "button" %>
    <%= link_to "フェーズ作成", new_league_phase_path(@league), class: "button button--primary" %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2>Phases</h2>
    <ul class="compact-list">
      <% @phases.each do |phase| %>
        <li>
          <%= link_to phase.name, league_phase_path(@league, phase) %>
          <span class="muted">(<%= phase.kind %>)</span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2>Teams</h2>
    <ul class="compact-list">
      <% @teams.each do |team| %>
        <li>
          <strong><%= team.display_name %></strong>
          <span class="muted">
            <% if team.block %>
              / <%= team.block.name %>
            <% end %>
            / 参加者 <%= team.participants.size %>
          </span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2>Participants</h2>
    <ul class="compact-list">
      <% @participants.first(12).each do |participant| %>
        <li><%= participant.display_name %> <span class="muted">/ <%= participant.team.display_name %></span></li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2>Recent Matches</h2>
    <% if @recent_matches.any? %>
      <ul class="record-list">
        <% @recent_matches.each do |match| %>
          <li><%= render "matches/row", match: match %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy">対戦はまだありません。</p>
    <% end %>
  </article>
</section>
