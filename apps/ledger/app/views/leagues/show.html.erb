<% page_title @league.name %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@league.name)
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("leagues.eyebrow") %></p>
    <h1><%= @league.name %></h1>
    <p class="muted"><%= t("leagues.meta", number: @league.display_number, status: translated_enum("enums.league.status", @league.status)) %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.edit"), edit_league_path(id: @league), class: "button" %>
    <%= link_to t("actions.manage_teams"), league_teams_path(league_id: @league), class: "button" %>
    <%= link_to t("actions.create_phase"), new_league_phase_path(league_id: @league), class: "button button--primary" %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2><%= t("leagues.team_management.title") %></h2>
    <p class="muted"><%= t("leagues.team_management.lede") %></p>
    <div class="page-actions">
      <%= link_to t("actions.manage_teams"), league_teams_path(league_id: @league), class: "button" %>
      <%= link_to t("actions.create_team"), new_league_team_path(league_id: @league), class: "button button--primary" %>
    </div>
  </article>

  <article class="panel">
    <h2><%= t("leagues.header_image.title") %></h2>
    <% if @league.header_image.attached? %>
      <div class="stack stack--compact">
        <p class="muted"><%= t("leagues.header_image.ready") %></p>
        <div class="image-preview-card">
          <%= image_tag @league.header_image, alt: t("leagues.form.header_image"), class: "image-preview-card__image" %>
        </div>
      </div>
    <% else %>
      <p class="empty-copy"><%= t("leagues.header_image.empty") %></p>
    <% end %>
  </article>

  <article class="panel">
    <h2><%= t("leagues.roster.title") %></h2>
    <ul class="compact-list">
      <li><strong><%= t("leagues.roster.min_members") %>:</strong> <%= @league.roster_min_members %></li>
      <li><strong><%= t("leagues.roster.max_members") %>:</strong> <%= @league.roster_max_members %></li>
      <li><strong><%= t("leagues.roster.lineup_size") %>:</strong> <%= @league.lineup_size %></li>
      <li><strong><%= t("leagues.roster.substitute_size") %>:</strong> <%= @league.substitute_size %></li>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.phases") %></h2>
    <ul class="compact-list">
      <% @phases.each do |phase| %>
        <li>
          <%= link_to phase.name, league_phase_path(league_id: @league, id: phase) %>
          <span class="muted">(<%= translated_enum("enums.phase.kind", phase.kind) %>)</span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.recent_matches") %></h2>
    <% if @recent_matches.any? %>
      <ul class="record-list">
        <% @recent_matches.each do |match| %>
          <li><%= render "matches/row", match: match %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("leagues.empty_matches") %></p>
    <% end %>
  </article>
</section>
