<% page_title @league.name %>
<% ruleset = @league.effective_ruleset_snapshot %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("leagues.eyebrow") %></p>
    <h1><%= @league.name %></h1>
    <p class="muted"><%= t("leagues.meta", rule_module_key: localized_ruleset_text(ruleset["name"]).presence || @league.rule_module_key, slug: @league.slug) %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.edit"), edit_league_path(id: @league), class: "button" %>
    <%= link_to t("actions.create_phase"), new_league_phase_path(league_id: @league), class: "button button--primary" %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2><%= t("leagues.ruleset.title") %></h2>
    <p class="muted"><%= localized_ruleset_text(ruleset["description"]) %></p>
    <ul class="compact-list">
      <li><strong><%= t("leagues.ruleset.template") %>:</strong> <%= localized_ruleset_text(ruleset["name"]) %></li>
      <li><strong><%= t("leagues.ruleset.key") %>:</strong> <code><%= @league.rule_module_key %></code></li>
      <% roster_rules = ruleset["roster_rules"] || {} %>
      <li>
        <strong><%= t("leagues.ruleset.roster") %>:</strong>
        <%= t("leagues.ruleset.roster_summary", min: roster_rules["min_members"], max: roster_rules["max_members"], lineup: roster_rules["lineup_size"], sub: roster_rules["substitute_size"]) %>
      </li>
      <li><strong><%= t("leagues.ruleset.default_match_rule_key") %>:</strong> <code><%= ruleset["default_match_rule_key"] %></code></li>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.ruleset.stages") %></h2>
    <ul class="compact-list">
      <% Array(ruleset["stages"]).each do |stage| %>
        <li>
          <strong><%= localized_ruleset_text(stage["name"]) %></strong>
          <span class="muted">/ <%= ruleset_stage_summary(stage) %></span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.phases") %></h2>
    <ul class="compact-list">
      <% @phases.each do |phase| %>
        <li>
          <%= link_to phase.name, league_phase_path(league_id: @league, id: phase) %>
          <span class="muted">(<%= translated_enum("enums.phase.kind", phase.kind) %>)</span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.teams") %></h2>
    <ul class="compact-list">
      <% @teams.each do |team| %>
        <li>
          <strong><%= team.display_name %></strong>
          <span class="muted">
            <% if team.block %>
              / <%= team.block.name %>
            <% end %>
            / <%= t("labels.participants_count", count: team.participants.size) %>
          </span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.participants") %></h2>
    <ul class="compact-list">
      <% @participants.first(12).each do |participant| %>
        <li><%= participant.display_name %> <span class="muted">/ <%= participant.team.display_name %></span></li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("leagues.recent_matches") %></h2>
    <% if @recent_matches.any? %>
      <ul class="record-list">
        <% @recent_matches.each do |match| %>
          <li><%= render "matches/row", match: match %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("leagues.empty_matches") %></p>
    <% end %>
  </article>
</section>
