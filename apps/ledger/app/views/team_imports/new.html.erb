<% page_title t("team_imports.title_new", league: @league.name) %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@league.name, league_path(id: @league)),
  breadcrumb_item(t("teams.eyebrow"), league_teams_path(league_id: @league)),
  breadcrumb_item(t("actions.import_teams_csv"))
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("team_imports.eyebrow") %></p>
    <h1><%= t("team_imports.title_new", league: @league.name) %></h1>
    <p class="muted"><%= t("team_imports.lede") %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_teams_path(league_id: @league), class: "button" %>
    <%= link_to t("actions.download_csv_template"), template_league_team_import_path(league_id: @league), class: "button" %>
  </div>
</section>

<section class="panel stack">
  <div>
    <h2><%= t("team_imports.template.title") %></h2>
    <p class="muted"><%= t("team_imports.template.description") %></p>
  </div>

  <div class="stack stack--compact">
    <code><%= TeamImports::CsvUpserter.headers_for.join(",") %></code>
    <% TeamImports::CsvUpserter.sample_rows_for.each do |row| %>
      <code><%= row.join(",") %></code>
    <% end %>
    <ul class="compact-list">
      <% TeamImports::CsvUpserter::HEADERS.each do |header| %>
        <li><strong><%= t("team_imports.template.headers.#{header}") %></strong>: <%= t("team_imports.template.columns.#{header}") %></li>
      <% end %>
    </ul>
  </div>
</section>

<section class="panel">
  <%= render "shared/errors", record: @team_import %>

  <%= form_with model: @team_import, url: league_team_import_path(league_id: @league), class: "stack" do |form| %>
    <div class="field">
      <%= form.label :file, t("team_imports.form.file") %>
      <%= form.file_field :file, accept: ".csv,text/csv", required: true %>
      <p class="ghost-note"><%= t("team_imports.form.file_hint") %></p>
    </div>

    <div class="page-actions">
      <%= link_to t("actions.download_csv_template"), template_league_team_import_path(league_id: @league), class: "button" %>
      <%= form.submit t("team_imports.form.submit"), class: "button button--primary" %>
    </div>
  <% end %>
</section>
