<% page_title t("dashboard.title") %>

<section class="page-header dashboard-hero">
  <div class="dashboard-hero__copy">
    <p class="eyebrow"><%= t("dashboard.eyebrow") %></p>
    <h1><%= t("dashboard.title") %></h1>
    <p class="muted"><%= t("dashboard.lede") %></p>
    <div class="hero-metrics">
      <span class="metric-chip"><strong><%= @today_matches.count %></strong><span><%= t("dashboard.metrics.today_matches") %></span></span>
      <span class="metric-chip"><strong><%= @result_pending_matches.count %></strong><span><%= t("dashboard.metrics.result_pending") %></span></span>
    </div>
  </div>
  <div class="page-actions">
    <%= link_to t("leagues.title_index"), leagues_path, class: "button" %>
    <%= link_to t("organizer_members.title_index"), organizer_members_path, class: "button" %>
    <%= link_to t("actions.create_league"), new_league_path, class: "button button--primary" %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2><%= t("dashboard.sections.today_matches") %></h2>
    <% if @today_matches.any? %>
      <ul class="record-list">
        <% @today_matches.each do |match| %>
          <li><%= render "matches/row", match: match %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("dashboard.empty.today_matches") %></p>
    <% end %>
  </article>

  <article class="panel">
    <h2><%= t("dashboard.sections.result_pending") %></h2>
    <% if @result_pending_matches.any? %>
      <ul class="record-list">
        <% @result_pending_matches.each do |match| %>
          <li><%= render "matches/row", match: match %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("dashboard.empty.result_pending") %></p>
    <% end %>
  </article>

  <article class="panel">
    <h2><%= t("dashboard.sections.leagues") %></h2>
    <% if @leagues.any? %>
      <ul class="compact-list">
        <% @leagues.each do |league| %>
          <li><%= link_to league.name, league_path(id: league) %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("dashboard.empty.leagues") %></p>
    <% end %>
  </article>
</section>
