<%= render "shared/errors", record: team %>

<% team_form_url = team.persisted? ? league_team_path(league_id: league, id: team) : league_teams_path(league_id: league) %>

<%= form_with model: team, url: team_form_url, class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :display_name, t("teams.form.display_name") %>
      <%= form.text_field :display_name, required: true %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :status, t("teams.form.status") %>
      <%= form.select :status, enum_options("enums.team.status", %w[active inactive withdrawn]) %>
      <p class="ghost-note"><%= t("teams.form.status_hint", draft_label: translated_enum("enums.league.status", "draft"), withdrawn_label: translated_enum("enums.team.status", "withdrawn")) %></p>
    </div>
  </div>

  <div class="field">
    <%= form.label :notes, t("teams.form.notes") %>
    <%= form.text_area :notes, rows: 4 %>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), team.persisted? ? league_team_path(league_id: league, id: team) : league_teams_path(league_id: league), class: "button" %>
    <%= form.submit(team.persisted? ? t("teams.submit_update") : t("teams.submit_create"), class: "button button--primary") %>
  </div>
<% end %>
