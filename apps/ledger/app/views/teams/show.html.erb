<% page_title @team.display_name %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@league.name, league_path(id: @league)),
  breadcrumb_item(t("teams.eyebrow"), league_teams_path(league_id: @league)),
  breadcrumb_item(@team.display_name)
]) %>

<section class="page-header">
  <div class="team-show-header">
    <% if @team.icon.attached? %>
      <%= image_tag @team.icon, alt: @team.display_name, class: "team-show-icon" %>
    <% end %>
    <div>
      <p class="eyebrow"><%= t("teams.eyebrow") %></p>
      <h1><%= @team.display_name %></h1>
      <p class="muted"><%= [translated_enum("enums.team.status", @team.status), @team.dropped? ? translated_enum("enums.team.drop_kind", @team.drop_kind) : nil, @team.block&.name, t("labels.participants_count", count: @participants.size)].compact.join(" / ") %></p>
    </div>
  </div>
  <div class="page-actions">
    <% if @return_to.present? %>
      <%= link_to t("teams.back_to_result_entry"), @return_to, class: "button button--primary" %>
    <% end %>
    <%= link_to t("actions.back"), league_teams_path(league_id: @league), class: "button" %>
    <% if can_manage? %>
      <%= link_to t("actions.edit"), edit_league_team_path(league_id: @league, id: @team), class: "button" %>
      <%= link_to t("actions.create_participant"), new_league_team_participant_path(league_id: @league, team_id: @team), class: "button button--primary" %>
    <% end %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2><%= t("teams.sections.participants") %></h2>
    <% if @participants.any? %>
      <ul class="compact-list">
        <% @participants.each do |participant| %>
          <li>
            <strong><%= participant.display_name %></strong>
            <%= status_badge translated_enum("enums.participant.participant_role", participant.participant_role), "neutral" %>
            <span class="muted">
              <% if participant.member_id.present? %>
                / <%= t("labels.member_id") %>: <%= participant.member_id %>
              <% end %>
              / <%= t("labels.number") %> <%= participant.position || "-" %>
              / <%= translated_enum("enums.participant.status", participant.status) %>
            </span>
            <% if can_manage? %>
              <%= link_to t("actions.edit"), edit_league_team_participant_path(league_id: @league, team_id: @team, id: participant), class: "inline-link" %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-copy"><%= t("teams.empty_participants") %></p>
    <% end %>
  </article>

  <% if can_manage? %>
    <article class="panel">
      <div class="panel-header">
        <h2><%= t("participants.title_new_inline") %></h2>
        <%= link_to t("actions.create_participant"), new_league_team_participant_path(league_id: @league, team_id: @team), class: "button" %>
      </div>
      <%= render "participants/form", league: @league, team: @team, participant: @participant %>
    </article>
  <% end %>
</section>

<% if can_manage? %>
  <section class="dashboard-grid">
    <article class="panel">
      <h2><%= t("teams.schedule_token.title") %></h2>
      <p class="muted"><%= t("teams.schedule_token.lede") %></p>
      <% if @team.schedule_token.present? %>
        <div class="kv-list">
          <div>
            <span><%= t("teams.schedule_token.share_url") %></span>
            <strong>
              <code><%= team_schedule_portal_url(token: @team.schedule_token, locale: nil, host: request.host_with_port, protocol: request.protocol) %></code>
            </strong>
          </div>
          <div>
            <span><%= t("teams.schedule_token.generated_at") %></span>
            <strong><%= l(@team.schedule_token_generated_at.in_time_zone("Asia/Tokyo"), format: :long) if @team.schedule_token_generated_at %></strong>
          </div>
        </div>
        <div class="page-actions">
          <%= button_to t("teams.schedule_token.regenerate"),
            league_team_schedule_token_path(league_id: @league, team_id: @team),
            method: :post,
            class: "button",
            form: { data: { turbo_confirm: t("teams.schedule_token.regenerate_confirm") } } %>
          <%= button_to t("teams.schedule_token.revoke"),
            league_team_schedule_token_path(league_id: @league, team_id: @team),
            method: :delete,
            class: "button button--danger",
            form: { data: { turbo_confirm: t("teams.schedule_token.revoke_confirm") } } %>
        </div>
      <% else %>
        <p class="muted"><%= t("teams.schedule_token.empty") %></p>
        <%= button_to t("teams.schedule_token.generate"),
          league_team_schedule_token_path(league_id: @league, team_id: @team),
          method: :post,
          class: "button button--primary" %>
      <% end %>
    </article>
  </section>
<% end %>

