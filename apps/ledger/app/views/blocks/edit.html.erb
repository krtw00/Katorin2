<% page_title t("blocks.title_edit") %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("blocks.eyebrow") %></p>
    <h1><%= t("blocks.title_edit") %></h1>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_phase_path(league_id: @phase.league, id: @phase), class: "button" %>
    <%= button_to t("actions.delete"), phase_block_path(phase_id: @phase, id: @block), method: :delete, class: "button button--danger", form: { data: { turbo_confirm: t("blocks.delete_confirm") } } %>
  </div>
</section>

<section class="panel">
  <%= render "form", phase: @phase, block: @block %>
</section>
