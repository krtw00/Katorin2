<%= render "shared/errors", record: phase %>

<%= form_with model: phase, url: update_bracket_league_phase_path(league_id: league, id: phase), method: :patch, class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :bracket_participant_count, t("phases.form.bracket_participant_count") %>
      <%= form.number_field :bracket_participant_count, min: 0, step: 1 %>
      <p class="ghost-note"><%= t("phases.form.bracket_participant_count_hint") %></p>
    </div>

    <div class="field">
      <%= form.label :bracket_lane_count, t("phases.form.bracket_region_count") %>
      <%= form.select :bracket_lane_count, options_for_select([[1, 1], [2, 2], [4, 4]], phase.effective_bracket_region_count) %>
      <p class="ghost-note"><%= t("phases.form.bracket_region_count_hint") %></p>
    </div>

    <div class="field">
      <label class="checkbox">
        <%= form.check_box :third_place_match_enabled %>
        <span><%= t("phases.form.third_place_match_enabled") %></span>
      </label>
      <p class="ghost-note"><%= t("phases.form.third_place_match_enabled_hint") %></p>
    </div>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), league_phase_path(league_id: league, id: phase), class: "button" %>
    <%= form.submit t("phases.actions.save_bracket"), class: "button button--primary" %>
  </div>
<% end %>
