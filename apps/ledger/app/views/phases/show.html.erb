<% page_title @phase.name %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("phases.eyebrow") %></p>
    <h1><%= @phase.name %></h1>
    <p class="muted"><%= t("phases.meta", kind: translated_enum("enums.phase.kind", @phase.kind), bracket: @phase.bracket_enabled? ? t("labels.on") : t("labels.off")) %></p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_path(@league), class: "button" %>
    <%= link_to t("actions.edit"), edit_league_phase_path(@league, @phase), class: "button" %>
    <%= link_to t("actions.create_week"), new_phase_week_path(@phase), class: "button button--primary" %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <h2><%= t("phases.weeks") %></h2>
    <ul class="compact-list">
      <% @weeks.each do |week| %>
        <li>
          <%= link_to week.name, phase_week_path(@phase, week) %>
          <span class="muted">/ <%= t("phases.weeks_count", count: week.matches.size) %></span>
        </li>
      <% end %>
    </ul>
  </article>

  <article class="panel">
    <h2><%= t("phases.blocks") %></h2>
    <ul class="compact-list">
      <% @blocks.each do |block| %>
        <li><%= block.name %></li>
      <% end %>
    </ul>
  </article>
</section>
