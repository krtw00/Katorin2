<% page_title "#{@phase.name} #{t("phases.bracket")}" %>
<% set_breadcrumbs([
  breadcrumb_item(t("nav.home"), dashboard_path),
  breadcrumb_item(t("leagues.title_index"), leagues_path),
  breadcrumb_item(@league.name, league_path(id: @league)),
  breadcrumb_item(@phase.name, league_phase_path(league_id: @league, id: @phase)),
  breadcrumb_item(t("phases.bracket"))
]) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("phases.eyebrow") %></p>
    <h1><%= @phase.name %> / <%= t("phases.bracket") %></h1>
    <p class="muted">
      <%= phase_structure_summary(@phase) %>
      <% if @bracket[:participant_count].present? %>
        / <%= t("phases.bracket_summary", participants: @bracket[:participant_count], bracket_size: @bracket[:bracket_size], byes: @bracket[:bye_count]) %>
      <% end %>
    </p>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_phase_path(league_id: @league, id: @phase), class: "button" %>
    <% if can_manage? %>
      <%= link_to t("phases.actions.seed_assignment"), seed_assignment_league_phase_path(league_id: @league, id: @phase), class: "button" %>
      <%= link_to t("phases.actions.configure_bracket"), edit_bracket_league_phase_path(league_id: @league, id: @phase), class: "button" %>
    <% end %>
  </div>
</section>

<section class="panel panel--bracket">
  <% if @bracket_rounds.any? %>
    <div class="bracket-toolbar">
      <% @bracket_rounds.each do |round| %>
        <div class="bracket-toolbar__item">
          <strong><%= round.display_name %></strong>
        </div>
      <% end %>
    </div>

    <div class="bracket-canvas">
      <svg class="bracket-svg" viewBox="0 0 <%= @bracket[:width] %> <%= @bracket[:height] %>" width="<%= @bracket[:width] %>" height="<%= @bracket[:height] %>" role="img" aria-label="<%= @phase.name %> bracket">
        <defs>
          <linearGradient id="bracket-bg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#f8fbfd" />
            <stop offset="100%" stop-color="#eef5f8" />
          </linearGradient>
        </defs>

        <rect x="0" y="0" width="<%= @bracket[:width] %>" height="<%= @bracket[:height] %>" rx="18" fill="url(#bracket-bg)" />

        <% @bracket[:connectors].each do |connector| %>
          <path d="<%= connector[:d] %>" fill="none" stroke="#a9b6c5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        <% end %>

        <% @bracket[:labels].each do |label| %>
          <text x="<%= label[:x] %>" y="<%= label[:y] %>" class="bracket-svg__heading"><%= label[:text] %></text>
        <% end %>

        <% @bracket[:cards].each do |card| %>
          <a href="<%= can_manage? ? card[:edit_path] : card[:show_path] %>">
            <rect x="<%= card[:x] %>" y="<%= card[:y] %>" width="<%= card[:width] %>" height="<%= card[:height] %>" rx="16" class="bracket-svg__card" />
            <text x="<%= card[:x] + 16 %>" y="<%= card[:slot_meta_y] %>" class="bracket-svg__meta"><%= card[:slot_label] %></text>
            <text x="<%= card[:x] + 16 %>" y="<%= card[:home_text_y] %>" class="bracket-svg__team">
              <% card[:home_lines].each_with_index do |line, index| %>
                <tspan x="<%= card[:x] + 16 %>" dy="<%= index.zero? ? 0 : 18 %>"><%= line %></tspan>
              <% end %>
            </text>
            <text x="<%= card[:x] + 16 %>" y="<%= card[:vs_text_y] %>" class="bracket-svg__vs"><%= t("labels.vs") %></text>
            <text x="<%= card[:x] + 16 %>" y="<%= card[:away_text_y] %>" class="bracket-svg__team bracket-svg__team--away">
              <% card[:away_lines].each_with_index do |line, index| %>
                <tspan x="<%= card[:x] + 16 %>" dy="<%= index.zero? ? 0 : 18 %>"><%= line %></tspan>
              <% end %>
            </text>
            <% if card[:score].present? %>
              <text x="<%= card[:x] + card[:width] - 16 %>" y="<%= card[:score_y] %>" text-anchor="end" class="bracket-svg__score"><%= card[:score] %></text>
            <% end %>
            <% if card[:meta].present? %>
              <text x="<%= card[:x] + card[:width] - 16 %>" y="<%= card[:info_meta_y] %>" text-anchor="end" class="bracket-svg__meta"><%= card[:meta] %></text>
            <% end %>
          </a>
          <% if card[:ready] %>
            <a href="<%= card[:result_path] %>">
              <rect x="<%= card[:x] + card[:width] - 86 %>" y="<%= card[:pill_y] %>" width="72" height="18" rx="9" class="bracket-svg__pill" />
              <text x="<%= card[:x] + card[:width] - 50 %>" y="<%= card[:pill_text_y] %>" text-anchor="middle" class="bracket-svg__pill-text"><%= t("actions.edit_result") %></text>
            </a>
          <% end %>
        <% end %>
      </svg>
    </div>
  <% else %>
    <p class="empty-copy"><%= t("phases.empty_bracket") %></p>
  <% end %>
</section>
