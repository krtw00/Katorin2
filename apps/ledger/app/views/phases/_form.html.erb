<%= render "shared/errors", record: phase %>

<% phase_form_url = phase.persisted? ? league_phase_path(league_id: league, id: phase) : league_phases_path(league_id: league) %>

<%= form_with model: phase, url: phase_form_url, class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :stage_asset_id, t("phases.form.stage_asset") %>
      <%= form.select :stage_asset_id, stage_asset_options, { prompt: t("matches.form.select_prompt") }, required: true %>
      <p class="ghost-note"><%= t("phases.form.stage_asset_hint") %></p>
    </div>

    <div class="field">
      <%= form.label :name, t("phases.form.name") %>
      <%= form.text_field :name, placeholder: t("phases.form.name_placeholder") %>
      <p class="ghost-note"><%= t("phases.form.name_hint") %></p>
    </div>
  </div>

  <% if !phase.persisted? %>
    <p class="ghost-note"><%= t("phases.form.bracket_participant_count_later_hint") %></p>
  <% end %>
  <p class="ghost-note"><%= t("phases.form.position_hint") %></p>

  <div class="page-actions">
    <%= link_to t("actions.back"), phase.persisted? ? league_phase_path(league_id: league, id: phase) : league_path(id: league), class: "button" %>
    <%= form.submit class: "button button--primary" %>
  </div>
<% end %>
