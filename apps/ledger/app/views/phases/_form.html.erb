<%= render "shared/errors", record: phase %>

<%= form_with model: [league, phase], class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :name, t("phases.form.name") %>
      <%= form.text_field :name, required: true %>
    </div>

    <div class="field">
      <%= form.label :kind, t("phases.form.kind") %>
      <%= form.select :kind, enum_options("enums.phase.kind", Phase::KINDS.values) %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :position, t("phases.form.position") %>
      <%= form.number_field :position, min: 1, required: true %>
    </div>

    <div class="field">
      <%= form.label :rule_module_key, t("phases.form.rule_module_key") %>
      <%= form.text_field :rule_module_key, required: true %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :ranking_rule_key, t("phases.form.ranking_rule_key") %>
      <%= form.text_field :ranking_rule_key %>
    </div>

    <div class="field checkbox-field">
      <label>
        <%= form.check_box :bracket_enabled %>
        <%= t("phases.form.bracket_enabled") %>
      </label>
    </div>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), phase.persisted? ? league_phase_path(league_id: league, id: phase) : league_path(id: league), class: "button" %>
    <%= form.submit class: "button button--primary" %>
  </div>
<% end %>
