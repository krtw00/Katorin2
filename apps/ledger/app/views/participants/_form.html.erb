<%= render "shared/errors", record: participant %>

<% participant_form_url = participant.persisted? ? league_team_participant_path(league_id: league, team_id: team, id: participant) : league_team_participants_path(league_id: league, team_id: team) %>

<%= form_with model: participant, url: participant_form_url, class: "stack" do |form| %>
  <div class="field-grid">
    <div class="field">
      <%= form.label :display_name, t("participants.form.display_name") %>
      <%= form.text_field :display_name, required: true %>
    </div>

    <div class="field">
      <%= form.label :position, t("participants.form.position") %>
      <%= form.number_field :position, min: 1 %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :status, t("participants.form.status") %>
      <%= form.select :status, enum_options("enums.participant.status", %w[active inactive]) %>
    </div>
  </div>

  <div class="field">
    <%= form.label :notes, t("participants.form.notes") %>
    <%= form.text_area :notes, rows: 3 %>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), league_team_path(league_id: league, id: team), class: "button" if participant.persisted? %>
    <%= form.submit t(participant.persisted? ? "participants.submit_update" : "participants.submit_create"), class: "button button--primary" %>
  </div>
<% end %>
