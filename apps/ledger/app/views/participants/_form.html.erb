<%= render "shared/errors", record: participant %>

<% participant_form_url = participant.persisted? ? league_team_participant_path(league_id: league, team_id: team, id: participant) : league_team_participants_path(league_id: league, team_id: team) %>
<% return_to = local_assigns[:return_to] %>

<%= form_with model: participant, url: participant_form_url, class: "stack" do |form| %>
  <% if return_to.present? %>
    <%= hidden_field_tag :return_to, return_to %>
  <% end %>
  <div class="field">
    <%= form.label :display_name, t("participants.form.display_name") %>
    <%= form.text_field :display_name, required: true %>
  </div>

  <% member_ids = Array(participant.member_ids).reject(&:blank?) %>
  <div class="field">
    <%= form.label :member_ids, t("participants.form.member_ids") %>
    <% Participant::MAX_MEMBER_IDS.times do |index| %>
      <%= text_field_tag "participant[member_ids][]", member_ids[index], id: "participant_member_ids_#{index}", aria: { label: t("participants.form.member_ids_nth", number: index + 1) } %>
    <% end %>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :participant_role, t("participants.form.participant_role") %>
      <%= form.select :participant_role, enum_options("enums.participant.participant_role", Participant::PARTICIPANT_ROLES.values) %>
    </div>

    <div class="field">
      <%= form.label :position, t("participants.form.position") %>
      <%= form.number_field :position, min: 1 %>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <%= form.label :status, t("participants.form.status") %>
      <%= form.select :status, enum_options("enums.participant.status", %w[active inactive withdrawn]) %>
    </div>
  </div>

  <div class="field">
    <%= form.label :notes, t("participants.form.notes") %>
    <%= form.text_area :notes, rows: 3 %>
  </div>

  <div class="page-actions">
    <%= link_to t("actions.back"), league_team_path(league_id: league, id: team), class: "button" if participant.persisted? %>
    <%= form.submit t(participant.persisted? ? "participants.submit_update" : "participants.submit_create"), class: "button button--primary" %>
  </div>
<% end %>
