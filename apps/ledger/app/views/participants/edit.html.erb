<% page_title t("participants.title_edit", participant: @participant.display_name) %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("participants.eyebrow") %></p>
    <h1><%= t("participants.title_edit", participant: @participant.display_name) %></h1>
  </div>
  <div class="page-actions">
    <%= link_to t("actions.back"), league_team_path(league_id: @league, id: @team), class: "button" %>
    <%= button_to t("actions.delete"), league_team_participant_path(league_id: @league, team_id: @team, id: @participant), method: :delete, class: "button button--danger", form: { data: { turbo_confirm: t("participants.delete_confirm") } } %>
  </div>
</section>

<%= render "form", league: @league, team: @team, participant: @participant %>
